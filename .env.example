# Selects cypress/config/environments/<name>.json and matching test-data overrides.
CYPRESS_environment=dev

# Optional Cypress Cloud settings used only by record/parallel commands.
CYPRESS_RECORD_KEY=
CYPRESS_PROJECT_ID=

# Example credentials. Never commit real values; copy this file to .env.
CYPRESS_TEST_USERNAME=
CYPRESS_TEST_PASSWORD=

# Records every cypress run spec. Set false locally only when faster runs are needed.
CYPRESS_video=true

# Database writes in prod are blocked unless this is deliberately changed.
DATABASE_ALLOW_PROD_MUTATIONS=false

# IBM Db2 private connection strings. Use dedicated least-privilege test users.
DB2_DEV_CONNECTION_STRING=DATABASE=sample;HOSTNAME=db2-dev.example.com;PORT=50000;PROTOCOL=TCPIP;UID=replace_me;PWD=replace_me;
DB2_STAGING_CONNECTION_STRING=DATABASE=sample;HOSTNAME=db2-staging.example.com;PORT=50000;PROTOCOL=TCPIP;UID=replace_me;PWD=replace_me;
DB2_PROD_CONNECTION_STRING=DATABASE=sample;HOSTNAME=db2-prod.example.com;PORT=50000;PROTOCOL=TCPIP;UID=replace_me;PWD=replace_me;

# Snowflake private connection settings, separated by execution environment.
SNOWFLAKE_DEV_ACCOUNT=replace_me
SNOWFLAKE_DEV_USERNAME=replace_me
SNOWFLAKE_DEV_PASSWORD=replace_me
SNOWFLAKE_DEV_WAREHOUSE=replace_me
SNOWFLAKE_DEV_DATABASE=replace_me
SNOWFLAKE_DEV_SCHEMA=replace_me
SNOWFLAKE_DEV_ROLE=replace_me
SNOWFLAKE_STAGING_ACCOUNT=replace_me
SNOWFLAKE_STAGING_USERNAME=replace_me
SNOWFLAKE_STAGING_PASSWORD=replace_me
SNOWFLAKE_STAGING_WAREHOUSE=replace_me
SNOWFLAKE_STAGING_DATABASE=replace_me
SNOWFLAKE_STAGING_SCHEMA=replace_me
SNOWFLAKE_STAGING_ROLE=replace_me
SNOWFLAKE_PROD_ACCOUNT=replace_me
SNOWFLAKE_PROD_USERNAME=replace_me
SNOWFLAKE_PROD_PASSWORD=replace_me
SNOWFLAKE_PROD_WAREHOUSE=replace_me
SNOWFLAKE_PROD_DATABASE=replace_me
SNOWFLAKE_PROD_SCHEMA=replace_me
SNOWFLAKE_PROD_ROLE=replace_me

# Jira Cloud is opt-in. Store real values in local/CI secrets, never Git.
JIRA_ENABLED=false
JIRA_BASE_URL=https://your-company.atlassian.net
JIRA_EMAIL=replace_me@example.com
JIRA_API_TOKEN=replace_me
JIRA_PASS_TRANSITION=Done
JIRA_FAIL_TRANSITION=Failed
JIRA_ISSUE_KEY=
