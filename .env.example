# Selects cypress/config/environments/<name>.json and matching test-data overrides.
CYPRESS_environment=dev

# Optional Cypress Cloud settings used only by record/parallel commands.
CYPRESS_RECORD_KEY=
CYPRESS_PROJECT_ID=

# Example credentials. Never commit real values; copy this file to .env.
CYPRESS_TEST_USERNAME=
CYPRESS_TEST_PASSWORD=

# Set true to record local run videos. Failure screenshots remain enabled.
CYPRESS_video=false
