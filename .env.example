# Selects cypress/config/environments/<name>.json and matching test-data overrides.
CYPRESS_environment=dev

# Optional Cypress Cloud settings used only by record/parallel commands.
CYPRESS_RECORD_KEY=
CYPRESS_PROJECT_ID=

# Example credentials. Never commit real values; copy this file to .env.
CYPRESS_TEST_USERNAME=
CYPRESS_TEST_PASSWORD=

# Records every cypress run spec. Set false locally only when faster runs are needed.
CYPRESS_video=true

# Database writes in prod are blocked unless this is deliberately changed.
DATABASE_ALLOW_PROD_MUTATIONS=false

# Selects the Db2 endpoint profile used by the @db2 scenario: local or cloud.
DB2_CONNECTION_PROFILE=local

# IBM Db2 private connection strings. Use dedicated least-privilege test users.
# Local examples target a developer/on-premise Db2 endpoint.
DB2_DEV_LOCAL_CONNECTION_STRING=DATABASE=SAMPLE;HOSTNAME=localhost;PORT=50000;PROTOCOL=TCPIP;UID=replace_me;PWD=replace_me;
DB2_STAGING_LOCAL_CONNECTION_STRING=DATABASE=SAMPLE;HOSTNAME=db2-staging.internal;PORT=50000;PROTOCOL=TCPIP;UID=replace_me;PWD=replace_me;
DB2_PROD_LOCAL_CONNECTION_STRING=DATABASE=SAMPLE;HOSTNAME=db2-prod.internal;PORT=50000;PROTOCOL=TCPIP;UID=replace_me;PWD=replace_me;

# Cloud examples use the hostname/port from IBM Cloud service credentials.
# IBM Db2 on Cloud requires TLS; keep SECURITY=SSL in these connection strings.
DB2_DEV_CLOUD_CONNECTION_STRING=DATABASE=BLUDB;HOSTNAME=replace_me.databases.appdomain.cloud;PORT=replace_me;PROTOCOL=TCPIP;UID=replace_me;PWD=replace_me;SECURITY=SSL;
DB2_STAGING_CLOUD_CONNECTION_STRING=DATABASE=BLUDB;HOSTNAME=replace_me.databases.appdomain.cloud;PORT=replace_me;PROTOCOL=TCPIP;UID=replace_me;PWD=replace_me;SECURITY=SSL;
DB2_PROD_CLOUD_CONNECTION_STRING=DATABASE=BLUDB;HOSTNAME=replace_me.databases.appdomain.cloud;PORT=replace_me;PROTOCOL=TCPIP;UID=replace_me;PWD=replace_me;SECURITY=SSL;

# Snowflake private connection settings, separated by execution environment.
SNOWFLAKE_DEV_ACCOUNT=replace_me
SNOWFLAKE_DEV_USERNAME=replace_me
SNOWFLAKE_DEV_PASSWORD=replace_me
SNOWFLAKE_DEV_WAREHOUSE=replace_me
SNOWFLAKE_DEV_DATABASE=replace_me
SNOWFLAKE_DEV_SCHEMA=replace_me
SNOWFLAKE_DEV_ROLE=replace_me
SNOWFLAKE_STAGING_ACCOUNT=replace_me
SNOWFLAKE_STAGING_USERNAME=replace_me
SNOWFLAKE_STAGING_PASSWORD=replace_me
SNOWFLAKE_STAGING_WAREHOUSE=replace_me
SNOWFLAKE_STAGING_DATABASE=replace_me
SNOWFLAKE_STAGING_SCHEMA=replace_me
SNOWFLAKE_STAGING_ROLE=replace_me
SNOWFLAKE_PROD_ACCOUNT=replace_me
SNOWFLAKE_PROD_USERNAME=replace_me
SNOWFLAKE_PROD_PASSWORD=replace_me
SNOWFLAKE_PROD_WAREHOUSE=replace_me
SNOWFLAKE_PROD_DATABASE=replace_me
SNOWFLAKE_PROD_SCHEMA=replace_me
SNOWFLAKE_PROD_ROLE=replace_me

# Jira Cloud is opt-in. Store real values in local/CI secrets, never Git.
JIRA_ENABLED=false
JIRA_BASE_URL=https://your-company.atlassian.net
JIRA_EMAIL=replace_me@example.com
JIRA_API_TOKEN=replace_me
JIRA_PASS_TRANSITION=Done
JIRA_FAIL_TRANSITION=Failed
JIRA_ISSUE_KEY=

# Zephyr Scale Cloud test-case creation is preview-only until explicitly enabled.
ZEPHYR_ENABLED=false
ZEPHYR_SCALE_BASE_URL=https://api.zephyrscale.smartbear.com/v2
ZEPHYR_SCALE_API_TOKEN=replace_me
# Optional defaults. Jira's project key is used when ZEPHYR_PROJECT_KEY is empty.
ZEPHYR_PROJECT_KEY=
ZEPHYR_FOLDER_ID=
ZEPHYR_PRIORITY_NAME=Normal
ZEPHYR_STATUS_NAME=Draft
ZEPHYR_OWNER_ACCOUNT_ID=
ZEPHYR_LABELS=automated-design
ZEPHYR_MAX_TEST_CASES=20
# Example: {"Automation Candidate":true,"Test Type":"Functional"}
ZEPHYR_CUSTOM_FIELDS_JSON=

# Post-build report bundle and external notifications. All channels are opt-in.
CI_NOTIFICATIONS_ENABLED=false
NOTIFICATION_FAIL_ON_ERROR=false
CUCUMBER_JSON_PATH=reports/cucumber-json/cucumber-report.json
# Optional artifact URL override. GitLab derives one from CI_JOB_URL by default.
CI_REPORT_URL=

# Slack app incoming webhook.
SLACK_NOTIFICATIONS_ENABLED=false
SLACK_WEBHOOK_URL=

# Microsoft Teams Workflows/incoming webhook.
TEAMS_NOTIFICATIONS_ENABLED=false
TEAMS_WEBHOOK_URL=

# SMTP email distribution lists support comma or semicolon separators.
EMAIL_NOTIFICATIONS_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
REPORT_EMAIL_FROM=e2e-reports@example.com
REPORT_EMAIL_TO=qa-team@example.com
REPORT_EMAIL_CC=
REPORT_EMAIL_BCC=
REPORT_EMAIL_SUBJECT_PREFIX=[E2E]
